{
  "rewrites": [
    {
      "source": "/os",
      "destination": "https://impact360-os.vercel.app/os"
    },
    {
      "source": "/os/:path*",
      "destination": "https://impact360-os.vercel.app/os/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://impact360-os.vercel.app/os/api/:path*"
    }
  ]
}
