{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/os",
      "destination": "https://impact-grid-lovat.vercel.app",
      "permanent": false
    },
    {
      "source": "/os/:path*",
      "destination": "https://impact-grid-lovat.vercel.app/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!static|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
