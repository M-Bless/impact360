{
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/os",
      "destination": "https://impact-grid-lovat.vercel.app/"
    },
    {
      "source": "/os/:path*",
      "destination": "https://impact-grid-lovat.vercel.app/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://impact-grid-lovat.vercel.app/_next/:path*"
    },
    {
      "source": "/((?!static|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
