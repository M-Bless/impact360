{
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/os",
      "destination": "https://impact-grid-kappa.vercel.app/os"
    },
    {
      "source": "/os/:path*",
      "destination": "https://impact-grid-kappa.vercel.app/os/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://impact-grid-kappa.vercel.app/os/api/:path*"
    },
    {
      "source": "/((?!os|api|static|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
